<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/intro_graph"
    app:startDestination="@id/firstFragment">

    <fragment
        android:id="@+id/firstFragment"
        android:name="com.smartyvpn.tfsmarty.view.slides.SlideFirstFragment"
        android:label="fragment_first"
        tools:layout="@layout/fragment_slide_first">
        <action
            android:id="@+id/action_firstFragment_to_secondFragment"
            app:destination="@id/secondFragment" />
    </fragment>
    <fragment
        android:id="@+id/secondFragment"
        android:name="com.smartyvpn.tfsmarty.view.slides.SlideSecondFragment"
        android:label="fragment_second"
        tools:layout="@layout/fragment_slide_second">
        <action
            android:id="@+id/action_secondFragment_to_thirdFragment"
            app:destination="@id/thirdFragment" />
    </fragment>
    <fragment
        android:id="@+id/thirdFragment"
        android:name="com.smartyvpn.tfsmarty.view.slides.SlideThirdFragment"
        android:label="fragment_third"
        tools:layout="@layout/fragment_slide_third" />
</navigation>