    </fragment>


    <fragment android:id="@+id/faqFragment" android:name="com.smartyvpn.tfsmarty.view.navmenu.FaqFragment" android:label="fragment_faq" tools:layout="@layout/fragment_faq"/>
    <dialog android:id="@+id/about_dialog" android:name="com.smartyvpn.tfsmarty.view.navmenu.AboutFragment" tools:layout="@layout/fragment_about"/>
