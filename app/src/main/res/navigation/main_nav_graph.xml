    <fragment android:id="@+id/homeFragment"
        android:name="com.smartyvpn.tfsmarty.view.MainFragment"
        tools:layout="@layout/fragment_main">
        <action android:id="@+id/action_homeFragment_to_faqFragment" app:destination="@id/faqFragment" app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left" app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right"/>
